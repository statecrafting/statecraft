{
  "name": "@stagecraft/fleet-native",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "spec-spine": { "spec": "006-fleet" },
  "description": "Stagecraft's fleet placement core (native kube-rs construction of the EnRaHiTu placement shape plus deploy/status/update/backup/remove) as a napi-rs native addon for the Encore.ts fleet service (spec 006).",
  "type": "commonjs",
  "main": "index.js",
  "types": "index.d.ts",
  "engines": { "node": ">=24" },
  "files": [
    "index.js",
    "index.d.ts"
  ],
  "napi": {
    "binaryName": "fleet-native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test:rust": "cargo test --no-default-features",
    "create-npm-dirs": "napi create-npm-dirs",
    "artifacts": "napi artifacts"
  },
  "devDependencies": {
    "@napi-rs/cli": "3.1.5"
  }
}
