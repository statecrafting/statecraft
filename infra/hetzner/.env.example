# infra/hetzner/.env.example
#
# GENERATED from infra/secrets/catalog.toml by `npm run secrets:example`.
# Do not edit by hand: edit the catalog and regenerate.
#
# This is the example for the OPERATOR .env at
#   ~/.config/statecrafting/infra/hetzner/.env
# (gitignored). It documents the platform secret surface (spec 010); it is
# NOT the root .env.example, which is spec 002's local-dev ledger doc.
#
# Validate a real .env with `npm run secrets:validate`.

# ==========================================================================
# User-supplied: the operator provides these.
# ==========================================================================

# Base apex domain the platform serves under (statecraft.ing). Every service host is a subdomain of it.
#   required: yes | consumer: cluster, cert-manager, app
DOMAIN=

# Registration email for the Let's Encrypt ACME accounts (both ClusterIssuers).
#   required: yes | consumer: cert-manager
LETSENCRYPT_EMAIL=

# Hetzner Cloud API token with read+write on the target project. Provisions nodes, load balancers, and CSI volumes.
#   required: yes | consumer: hetzner-k3s, hcloud-ccm, hcloud-csi
HCLOUD_TOKEN=

# Cloudflare API token scoped Zone.DNS:Edit on the statecraft.ing zone. Used by the DNS-01 ACME solver to prove control of every host.
#   required: yes | consumer: cert-manager (DNS-01 solver)
CLOUDFLARE_DNS_API_TOKEN=

# GitHub PAT with read:packages for pulling private GHCR images (the control-plane image and stamped app images).
#   required: yes | consumer: image pull (ghcr), fleet
GHCR_PAT=

# Base domain fleet places stamped single-container apps under (deployd.xyz). Distinct from DOMAIN, which is the control plane's own.
#   required: yes | consumer: fleet (plain env on the pod, not a Secret key)
FLEET_BASE_DOMAIN=

# Access key for the Hetzner Object Storage bucket that holds the fleet's restic backups of per-app volumes. Nothing in the image can mint it, so the deploy must supply it (spec 009 section 2.2).
#   required: yes | consumer: fleet (restic backups); one of the seven pod Secret keys
FLEET_S3_ACCESS_KEY_ID=

# Secret key paired with FLEET_S3_ACCESS_KEY_ID.
#   required: yes | consumer: fleet (restic backups); one of the seven pod Secret keys
FLEET_S3_SECRET_ACCESS_KEY=

# Access key for the Hetzner Object Storage bucket holding restic backups of the control plane's own /data volume.
#   required: yes | consumer: the control plane /data backup CronJob (spec 009 section 4.3 rule 2); never the app pod | group: platform_s3 (all-or-nothing)
PLATFORM_S3_ACCESS_KEY_ID=

# Secret key paired with PLATFORM_S3_ACCESS_KEY_ID.
#   required: yes | consumer: the control plane /data backup CronJob (spec 009 section 4.3 rule 2); never the app pod | group: platform_s3 (all-or-nothing)
PLATFORM_S3_SECRET_ACCESS_KEY=

# Access key for the statecraft-encore-object-storage Hetzner bucket, addressed by Encore's s3 object_storage backend. Replaces the dropped in-cluster minio.
#   required: yes | consumer: encore object_storage
OBJECT_STORAGE_S3_ACCESS_KEY_ID=

# Secret key paired with OBJECT_STORAGE_S3_ACCESS_KEY_ID.
#   required: yes | consumer: encore object_storage
OBJECT_STORAGE_S3_SECRET_ACCESS_KEY=

# Access key for the Hetzner Object Storage bucket that would hold rauthy's hiqlite database backups. Unwired: the entrypoint passes the rauthy process no S3 configuration.
#   required: yes | consumer: none today; held for the chassis change that wires rauthy hiqlite S3 backups (spec 009 section 4.8 item 2) | group: rauthy_s3 (all-or-nothing)
RAUTHY_S3_ACCESS_KEY_ID=

# Secret key paired with RAUTHY_S3_ACCESS_KEY_ID.
#   required: yes | consumer: none today; held for the chassis change that wires rauthy hiqlite S3 backups (spec 009 section 4.8 item 2) | group: rauthy_s3 (all-or-nothing)
RAUTHY_S3_SECRET_ACCESS_KEY=

# SMTP host for rauthy email (smtp.gmail.com). Hetzner blocks port 465; use 587 with STARTTLS.
#   required: yes | consumer: the embedded rauthy (mail transport); SMTP_PASSWORD is one of the seven pod Secret keys, the rest are non-secret plain env | group: smtp (all-or-nothing)
SMTP_URL=

# SMTP port (587 for STARTTLS).
#   required: yes | consumer: the embedded rauthy (mail transport); SMTP_PASSWORD is one of the seven pod Secret keys, the rest are non-secret plain env | group: smtp (all-or-nothing)
SMTP_PORT=

# SMTP auth username.
#   required: yes | consumer: the embedded rauthy (mail transport); SMTP_PASSWORD is one of the seven pod Secret keys, the rest are non-secret plain env | group: smtp (all-or-nothing)
SMTP_USERNAME=

# SMTP auth password (a Gmail app password, not the account password).
#   required: yes | consumer: the embedded rauthy (mail transport); SMTP_PASSWORD is one of the seven pod Secret keys, the rest are non-secret plain env | group: smtp (all-or-nothing)
SMTP_PASSWORD=

# From header for platform email (Admin <admin@statecraft.ing>).
#   required: yes | consumer: the embedded rauthy (mail transport); SMTP_PASSWORD is one of the seven pod Secret keys, the rest are non-secret plain env | group: smtp (all-or-nothing)
SMTP_FROM=

# Client id of the GitHub OAuth App rauthy federates to for GitHub login. rauthy 0.36 has no declarative bootstrap for upstream providers, so the seeder creates it through POST /auth/v1/providers/create.
#   required: yes | consumer: seed-rauthy Job (spec 009 section 4.5); its own Secret, never the app pod | group: github_upstream (all-or-nothing)
GITHUB_UPSTREAM_CLIENT_ID=

# Client secret paired with GITHUB_UPSTREAM_CLIENT_ID.
#   required: yes | consumer: seed-rauthy Job (spec 009 section 4.5); its own Secret, never the app pod | group: github_upstream (all-or-nothing)
GITHUB_UPSTREAM_CLIENT_SECRET=

# Client id of the Google OAuth client rauthy federates to for Google login. The seeder pass that exists on paper converges GitHub only, so this group is held rather than live.
#   required: yes | consumer: seed-rauthy Job, once it converges a second provider; spec 009 section 4.5 specifies only the GitHub one | group: google_upstream (all-or-nothing)
GOOGLE_UPSTREAM_CLIENT_ID=

# Client secret paired with GOOGLE_UPSTREAM_CLIENT_ID.
#   required: yes | consumer: seed-rauthy Job, once it converges a second provider; spec 009 section 4.5 specifies only the GitHub one | group: google_upstream (all-or-nothing)
GOOGLE_UPSTREAM_CLIENT_SECRET=

# ==========================================================================
# Generated: minted with crypto/rand or `npm run generate-keys`.
# ==========================================================================

# Restic repository password encrypting the control plane's /data backups. Losing BOTH this and the volume is unrecoverable: spec 009 section 4.3 states the volume is not reconstructible from git, and this password is the only thing that decrypts its backup. Custody belongs with the break-glass material, not with the fleet's credentials.
#   required: yes | consumer: the control plane /data backup CronJob (spec 009 section 4.3 rule 2); never the app pod | group: platform_s3 (all-or-nothing)
PLATFORM_S3_RESTIC_PASSWORD=

# Password for the statecraft Postgres role. CoreLedger runs the Postgres driver against it (spec 003). Delivered to the cluster as a SOPS secret and reached by the app through ENRAHITU_LEDGER_URL.
#   required: yes | consumer: postgres, app (CoreLedger driver)
POSTGRES_PASSWORD=

# Restic repository password encrypting the fleet's per-app volume backups of TENANT apps. Renamed from RESTIC_PASSWORD on 2026-07-20 to disambiguate it from PLATFORM_S3_RESTIC_PASSWORD, which protects the control plane's own /data volume; an unqualified name could not distinguish the two backup domains. Nothing in the image can mint it, so the deploy must supply it (spec 009 section 2.2). The addon passes the value into the backup Job as restic's own RESTIC_PASSWORD env var, which is restic's CLI contract and is not renamed.
#   required: yes | consumer: fleet (restic backups); one of the seven pod Secret keys
FLEET_S3_RESTIC_PASSWORD=

# RS256 private key (PEM) signing access tokens. Locally it is read from keys/access-private.pem by the dev fallback in backend/lib/secrets.ts; in the container the entrypoint exports it from /data/keys/.
#   required: no | consumer: local dev run (npm run generate-keys); in-container it is self-generated, so injecting it is forbidden
JWT_PRIVATE_KEY=

# RS256 public key (PEM) verifying access tokens. Public half of JWT_PRIVATE_KEY.
#   required: no | consumer: local dev run (npm run generate-keys); in-container it is self-generated, so injecting it is forbidden
JWT_PUBLIC_KEY=

# RS256 private key (PEM) signing refresh tokens. Locally it is read from keys/refresh-private.pem; in the container the entrypoint exports it from /data/keys/.
#   required: no | consumer: local dev run (npm run generate-keys); in-container it is self-generated, so injecting it is forbidden
JWT_REFRESH_PRIVATE_KEY=

# RS256 public key (PEM) verifying refresh tokens. Public half of JWT_REFRESH_PRIVATE_KEY.
#   required: no | consumer: local dev run (npm run generate-keys); in-container it is self-generated, so injecting it is forbidden
JWT_REFRESH_PUBLIC_KEY=

# ==========================================================================
# Provider-produced: a provider hands these back (GitHub App, rauthy).
# ==========================================================================

# Numeric id of the statecraft GitHub App. Not sensitive, but injected as an Encore secret alongside its private key.
#   required: yes | consumer: app (github app); one of the seven pod Secret keys
GITHUB_APP_ID=

# Base64 of the statecraft GitHub App private key (PEM). Mints short-lived per-installation tokens (spec 004).
#   required: yes | consumer: app (github app); one of the seven pod Secret keys
GITHUB_APP_PRIVATE_KEY_B64=

# Secret GitHub signs App webhook deliveries with; the webhook endpoint verifies it. Returned by the App manifest conversion.
#   required: yes | consumer: app (github webhooks); one of the seven pod Secret keys
GITHUB_WEBHOOK_SECRET=

# Client secret of the confidential OIDC client the control plane logs in through. first-boot.mjs mints it into /data/keys/rauthy-client-secret and seeds the same value into the rauthy client bootstrap, and the entrypoint exports it from there. The client id is hardcoded to `enrahitu` by the entrypoint and is no longer a catalog key.
#   required: no | consumer: local dev run (npm run dev:idp-secret); in-container it is self-generated, so injecting it is forbidden
RAUTHY_CLIENT_SECRET=

# Rauthy admin API key in the form <name>$<secret>, used by the seeder to create the GitHub upstream provider. Only the provider needs the API: the OIDC client is seeded declaratively at first boot and scopes are not converged at all. Not required yet, because first-boot.mjs does not compose api_keys.json (spec 009 section 4.8 item 3), so rauthy has not handed this value back.
#   required: no | consumer: seed-rauthy Job (spec 009 section 4.5); its own Secret, never the app pod
RAUTHY_ADMIN_TOKEN=

# ==========================================================================
# Derived: computed from another value (must equal the formula).
# ==========================================================================

# Base64 dockerconfigjson (derived from GHCR_PAT) that fleet attaches to placed pods so they can pull private GHCR images.
#   required: yes | consumer: fleet (image pull)
FLEET_IMAGE_PULL_SECRET=
