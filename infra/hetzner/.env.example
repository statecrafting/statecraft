# infra/hetzner/.env.example
#
# GENERATED from infra/secrets/catalog.toml by `npm run secrets:example`.
# Do not edit by hand: edit the catalog and regenerate.
#
# This is the example for the OPERATOR .env at
#   ~/.config/statecrafting/infra/hetzner/.env
# (gitignored). It documents the platform secret surface (spec 010); it is
# NOT the root .env.example, which is spec 002's local-dev ledger doc.
#
# Validate a real .env with `npm run secrets:validate`.

# ==========================================================================
# User-supplied: the operator provides these.
# ==========================================================================

# Base apex domain the platform serves under (statecraft.ing). Every service host is a subdomain of it.
#   required: yes | consumer: cluster, cert-manager, rauthy, app
DOMAIN=

# Registration email for the Let's Encrypt ACME accounts (both ClusterIssuers).
#   required: yes | consumer: cert-manager
LETSENCRYPT_EMAIL=

# Hetzner Cloud API token with read+write on the target project. Provisions nodes, load balancers, and CSI volumes.
#   required: yes | consumer: hetzner-k3s, hcloud-ccm, hcloud-csi
HCLOUD_TOKEN=

# Cloudflare API token scoped Zone.DNS:Edit on the statecraft.ing zone. Used by the DNS-01 ACME solver to prove control of every host.
#   required: yes | consumer: cert-manager (DNS-01 solver)
CLOUDFLARE_DNS_API_TOKEN=

# GitHub PAT with read:packages for pulling private GHCR images (the control-plane image and stamped app images).
#   required: yes | consumer: image pull (ghcr), fleet
GHCR_PAT=

# Base domain fleet places stamped single-container apps under (deployd.xyz). Distinct from DOMAIN, which is the control plane's own.
#   required: yes | consumer: fleet
FLEET_BASE_DOMAIN=

# Access key for the Hetzner Object Storage bucket that holds the fleet's restic backups of per-app volumes.
#   required: yes | consumer: fleet (restic backups)
FLEET_S3_ACCESS_KEY_ID=

# Secret key paired with FLEET_S3_ACCESS_KEY_ID.
#   required: yes | consumer: fleet (restic backups)
FLEET_S3_SECRET_ACCESS_KEY=

# Access key for the statecraft-encore-object-storage Hetzner bucket, addressed by Encore's s3 object_storage backend. Replaces the dropped in-cluster minio.
#   required: yes | consumer: encore object_storage
OBJECT_STORAGE_S3_ACCESS_KEY_ID=

# Secret key paired with OBJECT_STORAGE_S3_ACCESS_KEY_ID.
#   required: yes | consumer: encore object_storage
OBJECT_STORAGE_S3_SECRET_ACCESS_KEY=

# Access key for the Hetzner Object Storage bucket that holds rauthy's hiqlite database backups.
#   required: yes | consumer: rauthy (hiqlite S3 backup)
RAUTHY_S3_ACCESS_KEY_ID=

# Secret key paired with RAUTHY_S3_ACCESS_KEY_ID.
#   required: yes | consumer: rauthy (hiqlite S3 backup)
RAUTHY_S3_SECRET_ACCESS_KEY=

# SMTP host for rauthy email (smtp.gmail.com). Hetzner blocks port 465; use 587 with STARTTLS.
#   required: yes | consumer: rauthy | group: smtp (all-or-nothing)
SMTP_URL=

# SMTP port (587 for STARTTLS).
#   required: yes | consumer: rauthy | group: smtp (all-or-nothing)
SMTP_PORT=

# SMTP auth username.
#   required: yes | consumer: rauthy | group: smtp (all-or-nothing)
SMTP_USERNAME=

# SMTP auth password (a Gmail app password, not the account password).
#   required: yes | consumer: rauthy | group: smtp (all-or-nothing)
SMTP_PASSWORD=

# From header for platform email (Admin <admin@statecraft.ing>).
#   required: yes | consumer: rauthy | group: smtp (all-or-nothing)
SMTP_FROM=

# Client id of the GitHub OAuth App rauthy federates to for GitHub login. Seeded into rauthy via the admin API (rauthy 0.35 stores upstream providers in its DB, not config).
#   required: yes | consumer: rauthy (github upstream provider) | group: github_upstream (all-or-nothing)
GITHUB_UPSTREAM_CLIENT_ID=

# Client secret paired with GITHUB_UPSTREAM_CLIENT_ID.
#   required: yes | consumer: rauthy (github upstream provider) | group: github_upstream (all-or-nothing)
GITHUB_UPSTREAM_CLIENT_SECRET=

# Client id of the Google OAuth client rauthy federates to for Google login.
#   required: yes | consumer: rauthy (google upstream provider) | group: google_upstream (all-or-nothing)
GOOGLE_UPSTREAM_CLIENT_ID=

# Client secret paired with GOOGLE_UPSTREAM_CLIENT_ID.
#   required: yes | consumer: rauthy (google upstream provider) | group: google_upstream (all-or-nothing)
GOOGLE_UPSTREAM_CLIENT_SECRET=

# ==========================================================================
# Generated: minted with crypto/rand or `npm run generate-keys`.
# ==========================================================================

# Password for the statecraft Postgres role. CoreLedger runs the Postgres driver against it (spec 003).
#   required: yes | consumer: postgres, app (CoreLedger driver)
POSTGRES_PASSWORD=

# Secret keying the control plane's session cookies.
#   required: yes | consumer: app
SESSION_SECRET=

# Shared secret for rauthy's embedded hiqlite Raft cluster (SECRET_RAFT / HQL_SECRET_RAFT).
#   required: yes | consumer: rauthy
RAUTHY_RAFT_SECRET=

# Shared secret for rauthy's hiqlite API (SECRET_API / HQL_SECRET_API).
#   required: yes | consumer: rauthy
RAUTHY_API_SECRET=

# Plaintext bootstrap password for the rauthy admin account (BOOTSTRAP_ADMIN_PASSWORD_PLAIN). Rotated to a passkey after first login.
#   required: yes | consumer: rauthy (bootstrap admin)
RAUTHY_ADMIN_PASSWORD=

# Key id of the active rauthy encryption key (ENC_KEY_ACTIVE). Not itself secret; names which key in ENC_KEYS is active.
#   required: yes | consumer: rauthy
RAUTHY_ENC_KEY_ID=

# 32-byte base64 rauthy encryption key. ENC_KEYS is assembled as <RAUTHY_ENC_KEY_ID>/<RAUTHY_ENC_KEY>.
#   required: yes | consumer: rauthy
RAUTHY_ENC_KEY=

# Shared secret for the control plane's in-process hiqlite Raft channel.
#   required: yes | consumer: app (hiqlite)
HIQLITE_SECRET_RAFT=

# Shared secret for the control plane's in-process hiqlite API channel.
#   required: yes | consumer: app (hiqlite)
HIQLITE_SECRET_API=

# Restic repository password encrypting the fleet's per-app volume backups.
#   required: yes | consumer: fleet (restic backups)
RESTIC_PASSWORD=

# RS256 private key (PEM) signing access tokens. Minted by `npm run generate-keys`.
#   required: yes | consumer: app (auth)
JWT_PRIVATE_KEY=

# RS256 public key (PEM) verifying access tokens. Public half of JWT_PRIVATE_KEY.
#   required: yes | consumer: app (auth)
JWT_PUBLIC_KEY=

# RS256 private key (PEM) signing refresh tokens. Minted by `npm run generate-keys`.
#   required: yes | consumer: app (auth)
JWT_REFRESH_PRIVATE_KEY=

# RS256 public key (PEM) verifying refresh tokens. Public half of JWT_REFRESH_PRIVATE_KEY.
#   required: yes | consumer: app (auth)
JWT_REFRESH_PUBLIC_KEY=

# ==========================================================================
# Provider-produced: a provider hands these back (GitHub App, rauthy).
# ==========================================================================

# Numeric id of the statecraft GitHub App. Not sensitive, but injected as an Encore secret alongside its private key.
#   required: yes | consumer: app (github app)
GITHUB_APP_ID=

# Base64 of the statecraft GitHub App private key (PEM). Mints short-lived per-installation tokens (spec 004).
#   required: yes | consumer: app (github app)
GITHUB_APP_PRIVATE_KEY_B64=

# Secret GitHub signs App webhook deliveries with; the webhook endpoint verifies it. Returned by the App manifest conversion.
#   required: yes | consumer: app (github webhooks)
GITHUB_WEBHOOK_SECRET=

# Public client id of the rauthy SPA client (authorization_code + PKCE) the governance UI logs in with.
#   required: yes | consumer: app (spa auth), webapp
OIDC_SPA_CLIENT_ID=

# Client id of the rauthy machine-to-machine client (client_credentials).
#   required: yes | consumer: app (m2m)
OIDC_M2M_CLIENT_ID=

# Client secret paired with OIDC_M2M_CLIENT_ID.
#   required: yes | consumer: app (m2m)
OIDC_M2M_CLIENT_SECRET=

# Client id of the rauthy confidential client the control plane's server-side OIDC login uses.
#   required: yes | consumer: app (oidc login)
RAUTHY_CLIENT_ID=

# Client secret paired with RAUTHY_CLIENT_ID. Injected as an Encore secret (infra.config.json).
#   required: yes | consumer: app (oidc login)
RAUTHY_CLIENT_SECRET=

# Rauthy admin API key in the form <name>$<secret>. The seed job uses it to converge OIDC clients, scopes, and upstream providers.
#   required: yes | consumer: seed-rauthy job
RAUTHY_ADMIN_TOKEN=

# Client id of the rauthy client Grafana authenticates against (Grafana's sole auth path is rauthy generic_oauth).
#   required: yes | consumer: grafana
GRAFANA_OIDC_CLIENT_ID=

# Client secret paired with GRAFANA_OIDC_CLIENT_ID.
#   required: yes | consumer: grafana
GRAFANA_OIDC_CLIENT_SECRET=

# ==========================================================================
# Derived: computed from another value (must equal the formula).
# ==========================================================================

# https://<DOMAIN>. The control plane's own base URL.
#   required: yes | consumer: app, rauthy redirect
APP_BASE_URL=

# https://auth.<DOMAIN>. The rauthy issuer host.
#   required: yes | consumer: app, grafana, rauthy
RAUTHY_URL=

# Base64 dockerconfigjson (derived from GHCR_PAT) that fleet attaches to placed pods so they can pull private GHCR images.
#   required: yes | consumer: fleet (image pull)
FLEET_IMAGE_PULL_SECRET=
