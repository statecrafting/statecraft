# Stagecraft environment (example). Copy to .env for local dev; .env is
# gitignored. Substrate env names keep the chassis ENRAHITU_ prefix (the
# stamp recipe does not rename env prefixes); they configure this app all
# the same.

# --- CoreLedger driver selection (spec 003) ---
# The control plane runs CoreLedger on Postgres; stamped customer apps stay
# on libSQL/Turso. Driver is chosen by URL scheme, nothing else:
#   postgres://...  -> the Postgres driver (control-plane default)
#   file:...        -> libSQL, for quick local hacking without a database
# Start the dev database with `npm run dev:db` (docker/compose.postgres.yml),
# then set:
ENRAHITU_LEDGER_URL=postgres://statecraft:stagecraft@localhost:5433/statecraft
# libSQL alternative (no database needed):
# ENRAHITU_LEDGER_URL=file:./.data/ledger/statecraft.db
# Postgres connection pool size (default 10):
# ENRAHITU_LEDGER_POOL_SIZE=10

# --- Test-only: the parameterized ledger suite's Postgres arm (spec 003) ---
# When set, backend/core/ledger's Postgres tests run against this database;
# unset, they skip. CI sets it against a Postgres service container.
# TEST_POSTGRES_URL=postgres://statecraft:statecraft@localhost:5433/statecraft

# --- Auth / IdP (owned by specs 004/005; documented here as they land) ---
# JWT_PRIVATE_KEY, JWT_PUBLIC_KEY, JWT_REFRESH_PRIVATE_KEY,
# JWT_REFRESH_PUBLIC_KEY: RS256 PEMs from `npm run generate-keys`.
# RAUTHY_CLIENT_SECRET and RAUTHY_* issuer settings arrive with the rauthy
# same-origin proxy; the mock auth driver covers local dev without them.
