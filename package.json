{
  "name": "statecraft",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0",
  "spec-spine": { "spec": "002-app-shell" },
  "type": "module",
  "description": "statecraft: the governed agentic delivery control plane, stamped as an EnRaHiTu app (spec 002). Encore.ts services on the slimmed enrahitu chassis (@statecrafting/toolchain + @statecrafting/hiqlite-native), plus the governance and fleet native addons consumed as published @statecrafting packages (specs 008 and 006).",
  "engines": { "node": ">=24" },
  "scripts": {
    "dev": "enrahitu-dev",
    "build:app": "enrahitu-build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "generate-keys": "tsx scripts/generate-keys.ts",
    "secrets:example": "tsx infra/secrets/catalog.ts example",
    "secrets:validate": "tsx infra/secrets/catalog.ts validate",
    "secrets:check": "tsx infra/secrets/catalog.ts check",
    "dev:idp": "docker compose -f docker/compose.dev.yml up -d && node scripts/sync-dev-rauthy-secret.mjs",
    "dev:idp-secret": "node scripts/sync-dev-rauthy-secret.mjs",
    "dev:db": "docker compose -f docker/compose.postgres.yml up -d",
    "dev:web": "npm --prefix frontend run dev",
    "build:web": "npm --prefix frontend run build"
  },
  "dependencies": {
    "@statecrafting/hiqlite-native": "0.1.0",
    "@statecrafting/governance-native": "0.1.0",
    "@statecrafting/fleet-native": "0.1.0",
    "@libsql/client": "^0.17.4",
    "encore.dev": "^1.57.9",
    "jsonwebtoken": "^9.0.3",
    "openid-client": "^6.8.4",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@statecrafting/toolchain": "0.2.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  }
}
