{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "~encore/*": ["./encore.gen/*"]
    }
  },
  "exclude": ["node_modules", "encore.gen", "addon", "frontend", "vendor", ".encore"]
}
